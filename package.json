{
  "name": "verzus-platform",
  "version": "0.0.0",
  "private": true,
  "description": "Production-grade rebuild of the VERZUS competitive gaming platform.",
  "engines": {
    "node": "^22.12.0 || ^24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "preinstall": "node scripts/verify-node-version.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "env:check": "tsx scripts/verify-env.ts",
    "env:check:test": "tsx scripts/verify-env.ts .env.test",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "verify": "npm run env:check:test && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run check:boundaries && npm run build",
    "prepare": "husky",
    "clean": "node scripts/clean.mjs",
    "storybook": "storybook dev -p 6006 --host 127.0.0.1 --no-open",
    "build-storybook": "storybook build --output-dir storybook-static",
    "visual:test": "playwright test --config=playwright.visual.config.ts",
    "visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "verify:m2": "npm run verify && npm run build-storybook && npm run visual:test",
    "test:m3:shell-audit": "playwright test --config=playwright.m3-shell.config.ts",
    "verify:m3:shell-audit": "npm run typecheck && npm run test -- src/components/layout/app-shell/ShellFailureIsolation.test.tsx src/app/m3-shell-audit/page.test.tsx && npm run build && npm run test:m3:shell-audit",
    "test:m3:navigation": "playwright test --config=playwright.m3-final.config.ts",
    "visual:m3:test": "playwright test tests/visual/m3-shell.visual.spec.ts --config=playwright.visual.config.ts --project=mobile-390 --project=tablet-768 --project=desktop-1440",
    "visual:m3:update": "playwright test tests/visual/m3-shell.visual.spec.ts --config=playwright.visual.config.ts --project=mobile-390 --project=tablet-768 --project=desktop-1440 --update-snapshots",
    "verify:m3": "npm run verify && npm run build-storybook && npm run test:m3:shell-audit && npm run test:m3:navigation && npm run visual:m3:test",
    "test:m4": "vitest run --config vitest.m4.config.ts tests/integration/m4",
    "m4:verify:technical": "node scripts/verify-m4.mjs --technical",
    "m4:verify": "node scripts/verify-m4.mjs",
    "test:e2e:m4": "playwright test tests/e2e/m4",
    "test:visual:m4": "playwright test tests/visual/m4",
    "m4:visual-review": "node scripts/m4-visual-review.mjs",
    "m4:routes": "node scripts/m4-visual-review.mjs --scan-only",
    "m4:onboarding-references": "next dev --hostname 127.0.0.1 --port 3106",
    "m4:onboarding-responsive-references": "next dev --hostname 127.0.0.1 --port 3107",
    "m4:onboarding": "next dev --hostname 127.0.0.1 --port 3108",
    "test:m4:onboarding": "vitest run src/features/onboarding/ui/onboarding-route-access.test.ts",
    "test:m5:foundation": "vitest run src/features/play",
    "m5:verify:foundation": "npm run test:m5:foundation && npm run typecheck && npm run check:boundaries && npm run build",
    "m5:references": "next dev --hostname 127.0.0.1 --port 3109",
    "m5:play": "next dev --hostname 127.0.0.1 --port 3110",
    "test:m5:ui": "vitest run src/features/play/ui",
    "m5:verify:ui": "npm run test:m5:foundation && npm run test:m5:ui && npm run typecheck && npm run check:boundaries && npm run build",
    "test:m5:unit": "vitest run src/features/play",
    "test:e2e:m5": "playwright test tests/e2e/m5 --config=playwright.m5.config.ts --project=mobile-390 --project=desktop-1440",
    "m5:visual:update": "playwright test tests/visual/m5-play.visual.spec.ts --config=playwright.m5.config.ts --project=mobile-390 --project=tablet-768 --project=desktop-1440 --update-snapshots",
    "test:visual:m5": "playwright test tests/visual/m5-play.visual.spec.ts --config=playwright.m5.config.ts --project=mobile-390 --project=tablet-768 --project=desktop-1440",
    "m5:preview": "next dev --hostname 127.0.0.1 --port 3111",
    "m5:verify:technical": "npm run format:check && npm run lint && npm run typecheck && npm run test:m5:unit && npm run check:boundaries && npm run build && node scripts/verify-m5.mjs --technical",
    "m5:verify": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run check:boundaries && npm run build && npm run test:e2e:m5 && npm run test:visual:m5 && node scripts/verify-m5.mjs",
    "verify:retro-ui": "node scripts/verify-retro-ui.mjs",
    "verify:reference-ui": "node scripts/verify-reference-ui.mjs",
    "verify:stage5": "node scripts/verify-stage-5-platform.mjs",
    "stage5:preview": "next dev --hostname 127.0.0.1 --port 3113"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,md,yaml,yml}": "prettier --write"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.101.2",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/nextjs-vite": "10.5.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^17.4.2",
    "eslint": "^10",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "storybook": "10.5.0",
    "tsx": "^4.23.1",
    "typescript": "^7",
    "vitest": "^4.1.10"
  }
}
