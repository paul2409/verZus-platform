{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "next-env.d.ts",
    "src/features/crews/**/*.ts",
    "src/features/crews/**/*.tsx",
    "src/app/(platform)/crews/**/*.ts",
    "src/app/(platform)/crews/**/*.tsx",
    "src/app/api/crews/[crewId]/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
