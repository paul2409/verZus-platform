# Public application identity. Safe to expose to the browser.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_ENABLE_MOCKS=true
NEXT_PUBLIC_RELEASE_SHA=local
NEXT_PUBLIC_SENTRY_DSN=

# Server-only values. Never prefix secrets with NEXT_PUBLIC_.
# These may stay empty for M1 local development.
# They become mandatory in staging and production.
DATABASE_URL=
AUTH_SECRET=
REDIS_URL=
NEXT_PUBLIC_ENABLE_M5_PLAY_COMMAND_CENTER=true
NEXT_PUBLIC_ENABLE_M6_COMPETITIONS=true
NEXT_PUBLIC_ENABLE_M7_MATCH_OPERATIONS=true
