# Public application identity. Safe to expose to the browser.
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api
NEXT_PUBLIC_ENABLE_MOCKS=false
NEXT_PUBLIC_RELEASE_SHA=local
NEXT_PUBLIC_SENTRY_DSN=

# Server-only values. Never prefix secrets with NEXT_PUBLIC_.
# These may stay empty for M1 local development.
# They become mandatory in staging and production.
DATABASE_URL=postgresql://verzus:verzus_local_only@localhost:5432/verzus
DATABASE_SSL_MODE=disable
DATABASE_POOL_MAX=10
AUTH_SECRET=replace-with-at-least-32-random-characters
REDIS_URL=
NEXT_PUBLIC_ENABLE_M5_PLAY_COMMAND_CENTER=true
NEXT_PUBLIC_ENABLE_M6_COMPETITIONS=true
NEXT_PUBLIC_ENABLE_M7_MATCH_OPERATIONS=true

# VERZUS M8.10 leaderboard release controls
NEXT_PUBLIC_ENABLE_M8_LEADERBOARDS=true
NEXT_PUBLIC_ENABLE_M8_ENTITY_INTEL=true

# VERZUS M9.8 Crew release control
NEXT_PUBLIC_ENABLE_M9_CREWS=true

# VERZUS M10.8 Rewards release control
NEXT_PUBLIC_ENABLE_M10_REWARDS=true

# VERZUS M11.8 Player Profile release control
NEXT_PUBLIC_ENABLE_M11_PROFILES=true

# Identity delivery
NEXT_PUBLIC_APP_URL=http://localhost:3000
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=VERZUS <no-reply@verzus.local>
